{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/app",
        "destination": "/hydra.html"
      },
      {
        "source": "/app/**",
        "destination": "/hydra.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
