rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // allow users to read and write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // allow the admin email to read all user data
      allow read: if request.auth != null && request.auth.token.email == 'arshinmrelju@gmail.com';
      // allow users in the same group to read each other's data for leaderboard
      allow read: if request.auth != null && 
        resource.data.groupId != null && 
        resource.data.groupId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }
    
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'arshinmrelju@gmail.com';
    }
  }
}
